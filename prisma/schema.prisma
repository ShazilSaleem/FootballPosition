generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AssessmentResult {
  id                 String   @id @default(cuid())
  answers            Json
  scores             Json
  primaryKey         String
  primaryName        String
  primaryScore       Int
  primaryArchetype   String
  secondaryKey       String?
  secondaryName      String?
  secondaryScore     Int?
  secondaryArchetype String?
  tertiaryKey        String?
  tertiaryName       String?
  tertiaryScore      Int?
  tertiaryArchetype  String?
  strengths          String[]
  watchouts          String[]
  summary            String
  leadName           String?
  leadEmail          String?
  leadRole           String?
  leadCapturedAt     DateTime?
  feedbackRating     String?
  feedbackText       String?
  feedbackSubmittedAt DateTime?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  createdAt          DateTime @default(now())
}
